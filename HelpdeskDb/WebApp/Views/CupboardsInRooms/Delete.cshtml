@model App.BLL.DTO.CupboardInRoom

@{
    ViewData["Title"] = "Delete";
}

<h1>@Base.Resources.Common.DeleteTitle</h1>

<h3>@Base.Resources.Common.DeleteConfirmQuestion</h3>
<div>
    <h1>@App.Resources.Domain.CupboardInRoom.CupboardInRoomSingular</h1>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Comment)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Comment)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Cupboard)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Cupboard!.CodeName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Room)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Room!.Comment)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" value="Delete" class="btn btn-danger">
            @Base.Resources.Common.DeleteButton
        </button> |
        <a asp-action="Index">@Base.Resources.Common.BackToListLink</a>
    </form>
</div>
