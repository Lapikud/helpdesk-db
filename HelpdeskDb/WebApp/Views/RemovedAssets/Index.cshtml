@model IEnumerable<App.BLL.DTO.RemovedAssets>

@{
    ViewData["Title"] = "Index";
}

<h4>@App.Resources.Domain.RemovedAssets.RemovedAssetsTitle</h4>
@if (User.IsInRole("admins") || User.IsInRole("helpdesk_db_admins"))
{
    <p>
        <a asp-action="Create">@Base.Resources.Common.CreateNewLink</a>
    </p>
}
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Asset)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Comment)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RemovedBy)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Asset!.AssetName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Comment)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.RemovedBy)
            </td>
            @if (User.IsInRole("admins") || User.IsInRole("helpdesk_db_admins"))
            {
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">@Base.Resources.Common.EditLink</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">@Base.Resources.Common.DeleteLink</a>
                </td>
            }
        </tr>
}
    </tbody>
</table>
