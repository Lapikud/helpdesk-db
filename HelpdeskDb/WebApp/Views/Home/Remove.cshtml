@model AssetRemoveViewModel

@{
    ViewData["Title"] = "Remove";
}

<h1>@App.Resources.Views.Home.Remove.Title</h1>

<h3>@App.Resources.Views.Home.Remove.RemoveConfirmQuestion</h3>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Remove">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Asset.AssetName" class="control-label"></label>
                <input asp-for="Asset.AssetName" class="form-control" disabled />
                <span asp-validation-for="Asset.AssetName" class="text-danger"></span>
            </div>
            <input type="hidden" asp-for="Asset.AssetName" />
            <div class="form-group">
                <label asp-for="Asset.Comment" class="control-label"></label>
                <input asp-for="Asset.Comment" class="form-control" disabled />
                <span asp-validation-for="Asset.Comment" class="text-danger"></span>
            </div>
            <input type="hidden" asp-for="Asset.Comment" />
            @* CATEGORY *@
            <div class="form-group">
                <label asp-for="SelectedCategoryId" class="control-label"></label>
                <select asp-for="SelectedCategoryId" class="form-control" asp-items="Model.Categories" disabled></select>
                <span asp-validation-for="SelectedCategoryId" class="text-danger"></span>
            </div>
            @* Owner *@
            <div class="form-group">
                <label asp-for="SelectedOwnerId" class="control-label"></label>
                <select asp-for="SelectedOwnerId" class="form-control" asp-items="Model.Owners" disabled></select>
                <span asp-validation-for="SelectedOwnerId" class="text-danger"></span>
            </div>
            @* Location *@
            <div class="form-group">
                <label asp-for="@Model.SelectedLocationId" class="control-label"></label>
                <select asp-for="@Model.SelectedLocationId" class="form-control" asp-items="Model.Locations" disabled></select>
                <span asp-validation-for="@Model.SelectedLocationId" class="text-danger"></span>
            </div>
            <input type="hidden" asp-for="Asset.Id" />
            @* Comment with remove reason *@
            <div class="form-group">
                <label asp-for="Comment" class="control-label"></label>
                <input asp-for="Comment" class="form-control"/>
                <span asp-validation-for="Comment" class="text-danger"></span>
            </div>
            <button type="submit" value="Confirm Remove" class="btn btn-danger">
                @App.Resources.Views.Home.Remove.RemoveButton
            </button>
        </form>
    </div>
</div>

<div>
    <a asp-action="Overview">@Base.Resources.Common.BackToListLink</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}