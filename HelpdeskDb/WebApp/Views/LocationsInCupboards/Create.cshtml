@model WebApp.ViewModels.LocationInCupboardCreateEditVm

@{
    ViewData["Title"] = "Create";
}

<h1>@Base.Resources.Common.CreateTitle</h1>

<h4>@App.Resources.Domain.LocationInCupboard.LocationInCupboardSingular</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="LocationInCupboard.Location" class="control-label"></label>
                <select asp-for="LocationInCupboard.LocationId" class ="form-control" asp-items="Model.LocationSelectList"></select>
            </div>
            <div class="form-group">
                <label asp-for="LocationInCupboard.Cupboard" class="control-label"></label>
                <select asp-for="LocationInCupboard.CupboardId" class ="form-control" asp-items="Model.CupboardSelectList"></select>
            </div>
            <div class="form-group">
                <button type="submit" value="Create" class="btn btn-primary">
                    @Base.Resources.Common.CreateButton
                </button>
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">@Base.Resources.Common.BackToListLink</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
