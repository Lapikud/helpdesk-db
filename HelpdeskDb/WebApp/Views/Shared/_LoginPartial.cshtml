
<ul class="navbar-nav">
    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <li class="nav-item">
            <span class="nav-link text-dark">@App.Resources.Views.Shared._LoginPartial.Greeting, @User.Identity?.Name!</span>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="nav-link btn btn-link text-dark">@Base.Resources.Common.Logout</button>
            </form>
        </li>
    }
    else
    {
        @* <li class="nav-item"> *@
        @*     <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">@Base.Resources.Common.Register</a> *@
        @* </li> *@
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">@Base.Resources.Common.LoginLink</a>
        </li>
    }
</ul>