# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.

# PostgreSQL credentials — used by the db container
POSTGRES_DB=laphelpdeskdb
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password

# Connection string for the app container (host = docker service name)
DOCKER_DB_CONNECTION=Host=lapikudhelpdesk-db-postgres;Port=5432;Database=laphelpdeskdb;Username=your_postgres_user;Password=your_postgres_password;Include Error Detail=true

# Connection string for local dotnet run (host = localhost, loaded via DotNetEnv)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=laphelpdeskdb;Username=your_postgres_user;Password=your_postgres_password;Include Error Detail=true

# JWT signing key — use a long random string (e.g. openssl rand -base64 64)
JWTSecurity__Key=replace_with_long_random_secret

# CORS allowlist for the FrontendOnly policy. ASP.NET Core binds array
# sections from environment variables using __N indexing. Add one entry
# per allowed frontend origin (no trailing slash, scheme + host + optional port).
# Required in production once the frontend stops proxying via Next.js rewrites.
AllowedOrigins__0=http://localhost:3000
# AllowedOrigins__1=https://your-frontend.example.com

# FreeIPA service account used to authenticate the scoped IPA client when syncing
# roles outside the /login flow (e.g. on /renewRefreshToken). Needs read access to
# user_show (memberof_group) — typically any authenticated IPA user qualifies.
IpaServiceAccount__Username=your_ipa_service_account_uid
IpaServiceAccount__Password=your_ipa_service_account_password
