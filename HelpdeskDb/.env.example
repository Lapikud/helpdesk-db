# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.

# PostgreSQL credentials — used by the db container
POSTGRES_DB=laphelpdeskdb
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password

# Connection string for the app container (host = docker service name)
DOCKER_DB_CONNECTION=Host=lapikudhelpdesk-db;Port=5432;Database=laphelpdeskdb;Username=your_postgres_user;Password=your_postgres_password;Include Error Detail=true

# Connection string for local dotnet run (host = localhost, loaded via DotNetEnv)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=laphelpdeskdb;Username=your_postgres_user;Password=your_postgres_password;Include Error Detail=true

# JWT signing key — use a long random string (e.g. openssl rand -base64 64)
JWTSecurity__Key=replace_with_long_random_secret
